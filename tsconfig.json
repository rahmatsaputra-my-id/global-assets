{
  "compilerOptions": {
    "declaration": true,        
    "outDir": "dist",           
    "module": "ESNext",
    "target": "ES5",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],          
  "exclude": ["node_modules"]   
}